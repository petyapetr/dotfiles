[core]
	editor = vim
  excludesfile = ~/.gitignore

[color]
  diff = auto
  status = auto
  branch = auto
	ui = true

[push]
	default = current

[remote]
  pushDefault = origin

[branch]
	autosetuprebase = always

[pull]
	rebase = true

[init]
	defaultBranch = main

[credential "https://github.com"]
# MacOS
	# helper = !/opt/homebrew/bin/gh auth git-credential
# Windows
	helper = !/usr/bin/gh auth git-credential

[credential "https://gist.github.com"]
# MacOS
	helper = !/opt/homebrew/bin/gh auth git-credential
# Windows
	# helper = !/usr/bin/gh auth git-credential

[alias]
	l = "!. ~/.githelpers && pretty_git_log"
	la = "!git l --all"
	lr = "!git l -20"
	st = "status"
	sts = "status --short"
	c = "commit"
	cm = "commit -m"
	cw = "commit -m '(wip)'"
	amend = "commit --amend --no-edit"
	ammend = "commit --amend --no-edit"
	a = "add"
	aa = "add -A"
	d = "diff"
	dc = "diff --cached"
	sw = "switch"
	swc = "switch -c"
	b = "branch"
	br = "branch -r"
	bd = "branch --delete"
	brd = "push origin --delete"
	rb = "rebase"
	rbi = "!f() { git rebase -i HEAD~\"$1\"; }; f"
	abort = "rebase --abort"
	rs = "reset"
	rsh = "reset --hard"
	shls = "stash list"
	sh = "stash push"
	shs = "stash push --staged"
	shu = "stash push --keep-index" # u for unstaged
	shp = "stash pop"
	sha = "stash apply"
	p = "push"
	pf = "push --force"	
	f = "fetch"
	fp = "fetch --prune"
	sync = "!git fetch --all --prune && git pull --rebase"
	yeet = "!f() { git add -A && git commit -m \"$1\" && git push; }; f"
