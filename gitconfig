	name = Slava Zakharov
	email = 90175094+petyapetr@users.noreply.github.com

[core]
	editor = vim
  excludesfile = ~/.gitignore

[color]
  diff = auto
  status = auto
  branch = auto
	ui = true

[push]
	default = current

[remote]
  pushDefault = origin

[branch]
	autosetuprebase = always

[pull]
	rebase = true

[init]
	defaultBranch = main

[credential "https://github.com"]
# MacOS
	helper = !/opt/homebrew/bin/gh auth git-credential
# Windows
	# helper = !/usr/bin/gh auth git-credential

[credential "https://gist.github.com"]
# MacOS
	helper = !/opt/homebrew/bin/gh auth git-credential
# Windows
	# helper = !/usr/bin/gh auth git-credential

[alias]
	l = "!. ~/.githelpers && pretty_git_log"
	la = "!git l --all"
	lr = "!git l -20"
	st = "status"
	sts = "status -s"
	c = "commit"
	cm = "commit -m"
	cw = "commit -m '(wip)'"
	amend = "commit --amend --no-edit"
	ammend = "commit --amend --no-edit"
	a = "add"
	aa = "add -A"
	d = "diff"
	dc = "diff --cached"
	sw = "switch"
	swc = "switch -c"
	b = "branch"
	br = "branch -r"
	rb = "rebase"
	rbi = "rebase -i"
	pop = "stash pop"
	p = "push"
	pf = "push --force"	
	f = "fetch"
	fp = "fetch --prune"
